#!/bin/sh
MSG_FILE="$1"
FIRST_LINE=$(head -n 1 "$MSG_FILE")
LINE_COUNT=$(grep -c . "$MSG_FILE")

PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?: .+"

if ! echo "$FIRST_LINE" | grep -qE "$PATTERN"; then
    echo "Commit message must start with a type: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"
    echo "Example: fix: correct signature verification"
    exit 1
fi

if [ "$LINE_COUNT" -gt 1 ]; then
    echo "Commit message must be a single line, no description body"
    exit 1
fi

exit 0
